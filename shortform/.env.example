# Claude API (하이라이트/대본/리스크 심사)
ANTHROPIC_API_KEY=sk-ant-...

# YouTube Data API v3
YOUTUBE_API_KEY=AIza...            # 트렌드 스캔·댓글 수집용 (API 키로 충분)
YOUTUBE_CLIENT_SECRET_FILE=client_secret.json   # 업로드용 OAuth
YOUTUBE_TOKEN_FILE=token.youtube.json

# Instagram Graph API (Phase 2 후반)
IG_ACCESS_TOKEN=
IG_USER_ID=

# 운영
SHORTFORM_MODEL=claude-opus-4-8        # 대본·리스크 심사 (품질 우선)
SHORTFORM_MODEL_LIGHT=claude-haiku-4-5 # 소재 점수·댓글 마이닝 (비용 우선)
AUTO_PUBLISH=false                 # 발행 게이트 Level 2+에서만 의미 있음
DAILY_UPLOAD_LIMIT_YT=3
DAILY_UPLOAD_LIMIT_IG=3
ALERT_WEBHOOK_URL=                 # FAILED/BLOCKED 알림 (비우면 미사용)
OPTIMIZE_GOAL=subs                 # subs(YPP 진입 전) | retention(진입 후)
MONTHLY_LLM_BUDGET_USD=50          # 월 LLM 예산 상한 — 초과 시 호출 차단+알림

# 공급사 아웃리치 (미설정 시 초안 파일만 생성 — out/outreach/)
SELLER_NAME=                       # 예: 홍길동
SELLER_STORE=                      # 예: 쿠팡 OO스토어
SMTP_HOST=                         # 예: smtp.gmail.com (구글은 앱 비밀번호 필요)
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
OUTREACH_AUTO_SEND=false           # true면 email 채널 자동 발송
